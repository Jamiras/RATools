<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:jamiras="clr-namespace:Jamiras.Controls;assembly=Jamiras.UI.WPF"
                    xmlns:vm="clr-namespace:RATools.ViewModels">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ScriptViewer.xaml" />
        <ResourceDictionary Source="AchievementViewer.xaml" />
        <ResourceDictionary Source="RichPresenceViewer.xaml" />
        <ResourceDictionary Source="LeaderboardViewer.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <HierarchicalDataTemplate x:Key="navigationNodeTemplate" ItemsSource="{Binding Children}">
        <Grid HorizontalAlignment="Stretch" Height="13" Margin="-1,0,0,0">
            <Grid.Resources>
                <Style x:Key="navigationNodeContextMenuItemStyle" TargetType="MenuItem">
                    <Setter Property="Header" Value="{Binding Label}" />
                    <Setter Property="Command" Value="{Binding Command}" />
                    <Setter Property="CommandParameter" Value="{Binding CommandParameter}" />
                </Style>
                <ContextMenu x:Key="navigationNodeContextMenu" ItemsSource="{Binding ContextMenu}"
                             ItemContainerStyle="{StaticResource navigationNodeContextMenuItemStyle}" />
            </Grid.Resources>
            <Grid.Style>
                <Style TargetType="{x:Type Grid}">
                    <Setter Property="ContextMenu" Value="{StaticResource navigationNodeContextMenu}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ContextMenu}" Value="{x:Null}">
                            <Setter Property="ContextMenu" Value="{x:Null}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ContextMenu.Count}" Value="0">
                            <Setter Property="ContextMenu" Value="{x:Null}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="13" />
            </Grid.ColumnDefinitions>

            <!-- Modified (explicitly gray to match images) -->
            <TextBlock FontSize="10" VerticalAlignment="Center" Foreground="Gray" 
                       ToolTip="{Binding ModificationMessage}" Margin="-1,-2,0,0">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CompareState}" Value="NotGenerated">
                                <Setter Property="Text" Value="&#x25D6;" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CompareState}" Value="GeneratedOnly">
                                <Setter Property="Text" Value="&#x25CB;" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CompareState}" Value="LocalDiffers">
                                <Setter Property="Text" Value="&#x2BC3;" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CompareState}" Value="PublishedDiffers">
                                <Setter Property="Text" Value="&#x25D0;" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Image -->
            <Image Grid.Column="1" Width="12" Height="12" Margin="0,-1,0,-1"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Source="{Binding ImageResourcePath}" ToolTip="{Binding ImageTooltip}" />

            <!-- Name -->
            <TextBlock Grid.Column="2" Margin="2,-3,2,0" HorizontalAlignment="Stretch"
                       Text="{Binding Label}" TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Grid.ColumnSpan" Value="3" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ImageName}" Value="achievement">
                                <Setter Property="Grid.ColumnSpan" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Points -->
            <TextBlock Grid.Column="3" Margin="2,-2,2,0" HorizontalAlignment="Right">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ImageName}" Value="achievement">
                                <Setter Property="Text" Value="{Binding Points}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            
            <!-- Type -->
            <Image Grid.Column="4">
                <Image.Style>
                    <Style TargetType="{x:Type Image}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ImageName}" Value="achievement">
                                <Setter Property="Width" Value="13" />
                                <Setter Property="Height" Value="13" />
                                <Setter Property="Source" Value="{Binding TypeImage, TargetNullValue={x:Null}}" />
                                <Setter Property="ToolTip" Value="{Binding AchievementType}" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ImageName}" Value="achievement" />
                                    <Condition Binding="{Binding AchievementType}" Value="Missable" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Width" Value="11" />
                                <Setter Property="Height" Value="11" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
        </Grid>
    </HierarchicalDataTemplate>

    <DataTemplate DataType="{x:Type vm:GameViewModel}">
        <Grid Background="#F0F0F0" x:Name="gameGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="238" MinWidth="128" MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="480" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid IsEnabled="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Margin="6" Background="Red" x:Name="maxAchievementRowWidth" Height="10" />
                <ScrollBar Grid.Column="2" Orientation="Vertical" />
            </Grid>

            <TreeView ItemsSource="{Binding NavigationNodes}" HorizontalContentAlignment="Stretch"
                      ItemTemplate="{StaticResource navigationNodeTemplate}" x:Name="navigationNodes"
                      jamiras:TreeUtils.SelectedItem="{Binding SelectedNavigationNode}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource themedTreeView}">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource themedTreeViewItem}">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Margin" Value="1" />
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" ResizeDirection="Columns" />

            <ContentPresenter Grid.Column="2" Content="{Binding SelectedEditor}" />

            <Border Grid.Row="1" Grid.ColumnSpan="3" Height="20" Background="#C0C0C0" BorderBrush="DarkGray" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="4,0,4,0">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CoreAchievementCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Core(" />
                        <TextBlock Text="{Binding CoreAchievementCount}" Margin="-3,0,-3,0" />                        
                        <Run Text="): " />
                        <TextBlock Text="{Binding CoreAchievementPoints, FallbackValue=0}" Margin="-3,0,-3,0" />
                        <Run Text="pts" />
                    </TextBlock>
                    <TextBlock Grid.Column="1" Margin="4,0,4,0">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UnofficialAchievementCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Unofficial(" />
                        <TextBlock Text="{Binding UnofficialAchievementCount}" Margin="-3,0,-3,0" />
                        <Run Text="): " />
                        <TextBlock Text="{Binding UnofficialAchievementPoints, FallbackValue=0}" Margin="-3,0,-3,0" />
                        <Run Text="pts" />
                    </TextBlock>
                    <TextBlock Grid.Column="2" Margin="4,0,4,0" ToolTip="{Binding LocalFilePath}">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LocalAchievementCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Local(" />
                        <TextBlock Text="{Binding LocalAchievementCount}" Margin="-3,0,-3,0" />
                        <Run Text="): " />
                        <TextBlock Text="{Binding LocalAchievementPoints, FallbackValue=0}" Margin="-3,0,-3,0" />
                        <Run Text="pts" />
                    </TextBlock>

                    <Grid Grid.Column="3" Margin="4,0,24,0" HorizontalAlignment="Right">
                        <Grid.Style>
                            <Style TargetType="{x:Type Grid}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompileProgress}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ToolTip>
                            <TextBlock>
                                <Run Text="Processing line" />
                                <TextBlock Text="{Binding CompileProgressLine}" />
                            </TextBlock>
                        </Grid.ToolTip>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Processing" Margin="0,0,2,0" />
                        <Border Grid.Column="1" BorderThickness="1" BorderBrush="#808080" Background="#A0A0A0" Width="100" Height="10">
                            <Border Background="#80C080" Width="{Binding CompileProgress}" Height="8" 
                                    VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0" />
                        </Border>
                        <TextBlock Grid.Column="2" Margin="2,0,0,0" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding CompileProgress}" Margin="0,0,-2,0" />
                            <Run Text="%" />
                        </TextBlock>
                    </Grid>

                    <TextBlock Grid.Column="4" Margin="4,0,4,0" HorizontalAlignment="Right">
                        <Run Text="Ln " />
                        <TextBlock Text="{Binding Script.Editor.CursorLine, FallbackValue=0}" />
                        <Run Text="   Col " />
                        <TextBlock Text="{Binding Script.Editor.CursorColumn, FallbackValue=0}" />
                    </TextBlock>
                </Grid>
            </Border>

        </Grid>
    </DataTemplate>

</ResourceDictionary>